{
  "version": "9.4",
  "status": "supported",
  "api_root": "/gms/rest",
  "operations": {
    "orchestrator.inventory.summary": {
      "method": "GET",
      "path": "/appliances",
      "polling_hint_seconds": 120,
      "notes": ["Lightweight orchestrator inventory call."]
    },
    "orchestrator.topology": {
      "method": "GET",
      "path": "/topology",
      "polling_hint_seconds": 300,
      "notes": ["Used for dashboard topology views."]
    },
    "appliance.interfaces": {
      "method": "GET",
      "path": "/appliances/{appliance_id}/interfaces",
      "polling_hint_seconds": 5,
      "notes": ["Appliance near-real-time interface metrics."]
    },
    "appliance.tunnels": {
      "method": "GET",
      "path": "/appliances/{appliance_id}/tunnels",
      "polling_hint_seconds": 5,
      "notes": ["Tunnel state and overlay path visibility."]
    },
    "appliance.performance": {
      "method": "GET",
      "path": "/appliances/{appliance_id}/performance",
      "polling_hint_seconds": 5,
      "notes": ["CPU, memory, latency, jitter and loss."]
    },
    "appliance.routing": {
      "method": "GET",
      "path": "/appliances/{appliance_id}/routing",
      "polling_hint_seconds": 30,
      "notes": ["Routing snapshot for NOC and troubleshooting dashboards."]
    }
  }
}
